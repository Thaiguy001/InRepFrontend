            "readOnly": true
          },
          "username": {
            "type": "string",
            "nullable": true
          },
          "first_name": {
            "type": "string",
            "nullable": true
          },
          "last_name": {
            "type": "string",
            "nullable": true
          },
          "role": {
            "type": "string",
            "nullable": true
          },
          "phone_number": {
            "type": "string",
            "nullable": true
          },
          "team_id": {
            "type": "integer",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "UserUpdateProfile": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "nullable": true
          },
          "first_name": {
            "type": "string",
            "nullable": true
          },
          "last_name": {
            "type": "string",
            "nullable": true
          },
          "phone_number": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "UserAdminUpdate": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string",
            "nullable": true
          },
          "team_id": {
            "type": "integer",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "Team": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "readOnly": true
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        },
        "required": [
          "description",
          "name"
        ],
        "additionalProperties": false
      },
      "Filter": {
        "type": "object",
        "properties": {
          "value": {
            "nullable": true
          },
          "matchMode": {
            "type": "string"
          }
        },
        "required": [
          "matchMode"
        ],
        "additionalProperties": false
      },
      "Query": {
        "type": "object",
        "properties": {
          "first": {
            "type": "integer",
            "default": 0
          },
          "rows": {
            "type": "integer",
            "default": 10
          },
          "sortField": {
            "type": "string",
            "nullable": true
          },
          "sortOrder": {
            "type": "integer",
            "nullable": true
          },
          "filters": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/components/schemas/Filter"
            }
          },
          "global": {
            "type": "object",
            "additionalProperties": {},
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "Page": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "readOnly": true,
            "items": {
              "$ref": "#/components/schemas/Team"
            }
          },
          "total": {
            "type": "integer",
            "readOnly": true
          }
        },
        "additionalProperties": false
      }
